---
import BaseLayout from '../layouts/BaseLayout.astro';
import PlatformLinks from '../components/PlatformLinks.astro';
import { buildCanonicalUrl, formatDate, getPodcastData, toIsoDate } from '../lib/podcast';

const { podcast, episodes } = await getPodcastData();
const pageTitle = `${podcast.title} Podcast`;
const pageDescription =
  podcast.description ||
  'Explore all Dinosaur Stories episodes, from T. rex to Velociraptor, with science-based storytelling.';
const canonicalUrl = buildCanonicalUrl(Astro.site, '/');
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonicalUrl={canonicalUrl}
  ogImage={podcast.imageUrl}
  ogType="website"
  jsonLd={{
    '@context': 'https://schema.org',
    '@type': 'PodcastSeries',
    name: podcast.title,
    description: pageDescription,
    url: canonicalUrl,
    inLanguage: podcast.language,
    image: podcast.imageUrl,
    dateModified: toIsoDate(podcast.updatedAt),
  }}
>
  <section class="page-hero-section" aria-label="About the podcast">
    <div class="page-hero__mobile-head">
      <div class="page-hero__logo page-hero__logo--above">
        <img
          src="/logo.jpg"
          width="96"
          height="96"
          alt=""
          decoding="async"
          aria-hidden="true"
        />
      </div>
      <h1 class="page-hero__title page-hero__title--mobile">
        {podcast.title}
        <br />
        <span class="page-hero__title-suffix">Podcast</span>
      </h1>
    </div>
    <div class="page-hero">
      <div class="page-hero__row">
        <div class="page-hero__logo page-hero__logo--in-hero">
          <img
            src="/logo.jpg"
            width="256"
            height="256"
            alt="Dinosaur Stories podcast logo"
            decoding="async"
          />
        </div>
        <div class="page-hero__copy">
          <h1 class="page-hero__title page-hero__title--desktop">{podcast.title} Podcast</h1>
          <p class="lead">{pageDescription}</p>
          <PlatformLinks variant="hero" />
        </div>
      </div>
    </div>
  </section>
  <section aria-label="All episodes">
    <ul class="episode-list">
      {
        episodes.map((episode) => (
          <li>
            <article class="episode-card">
              {episode.imageUrl ? (
                <div class="episode-card__media">
                  <img src={episode.imageUrl} alt="" loading="lazy" width="400" height="400" />
                </div>
              ) : (
                <div class="episode-card__media episode-card__media--placeholder" aria-hidden="true" />
              )}
              <div class="episode-card__body">
                <h2>
                  <a href={`/episodes/${episode.slug}/`}>{episode.title}</a>
                </h2>
                <p class="episode-excerpt">{episode.descriptionText}</p>
              </div>
            </article>
          </li>
        ))
      }
    </ul>
  </section>
</BaseLayout>
